# Obtain keys from:
# - OpenAI: https://platform.openai.com/api-keys
# - Google AI Studio: https://aistudio.google.com/app/apikey
OPENAI_API_KEY=sk-your-openai-key
GEMINI_API_KEY=your-gemini-key
DATABASE_URL=sqlite:///./data/image_service.db
ASSET_ROOT=./data/assets
LOG_LEVEL=INFO
DEFAULT_PROVIDER=openai
# GPT Image models can require OpenAI organization verification. gpt-image-1 is the safe default;
# use gpt-image-1.5 per session/model override or here after verification is available.
DEFAULT_OPENAI_MODEL=gpt-image-1
# Current Gemini image defaults. Use GEMINI_PRO_IMAGE_MODEL as a documented premium override.
DEFAULT_GEMINI_MODEL=gemini-3.1-flash-image
GEMINI_PRO_IMAGE_MODEL=gemini-3-pro-image
DEFAULT_SAFETY_PROFILE=balanced
ENABLE_FALLBACK=false
MAX_TURN_CONTEXT=6
REQUEST_TIMEOUT_SECONDS=120
LOG_PROMPTS=false
